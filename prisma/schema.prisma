// Playbook — data model
// See playbook-mvp-spec.md §4 (Data model) and §2 (In scope).
// Prisma 7 "prisma-client" generator. DATABASE_URL is supplied via prisma.config.ts (dotenv).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth & user
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String
  emailVerified  DateTime?
  name           String?

  // Onboarding answers (spec §2.1)
  sport              String?
  year               String? // Freshman | Sophomore | Junior | Senior | Pro
  careerHorizonYears Int? // 1-12
  hasNilDeals        Boolean?
  estMonthlyNil      Int? // whole dollars, monthly NIL income estimate
  paymentChannels    String[] @default([]) // direct_deposit | school_collective | cash_venmo
  onboardingComplete Boolean  @default(false)

  // School sponsorship
  school   School? @relation(fields: [schoolId], references: [id])
  schoolId String?

  plaidItems   PlaidItem[]
  accounts     Account[]
  transactions Transaction[]
  rules        Rule[]
  alerts       Alert[]
  goals        Goal[]
  redeemedCode AccessCode? // the single-use code this user redeemed, if any

  // Input-payment addendum
  manualPayments  ManualPayment[]
  goalAllocations GoalAllocation[]
  reserveMarks    ReserveMark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String // the email being verified
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// School / access codes (spec §2.1). Codes are UNIQUE PER STUDENT and SINGLE-USE:
// a code locks to the first account that redeems it, so it can't be shared/reused.
// ---------------------------------------------------------------------------

model School {
  id          String       @id @default(cuid())
  name        String
  accessCodes AccessCode[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AccessCode {
  id        String   @id @default(cuid())
  code      String   @unique
  active    Boolean  @default(true)
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String

  // Single-use redemption: set when an account activates with this code.
  redeemedBy   User?     @relation(fields: [redeemedById], references: [id])
  redeemedById String?   @unique
  redeemedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Plaid (spec §2.2, §4 — access tokens encrypted at rest, never sent to client)
// ---------------------------------------------------------------------------

model PlaidItem {
  id                 String    @id @default(cuid())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  itemId             String    @unique // Plaid item_id
  accessTokenEnc     String // AES-256-GCM encrypted Plaid access_token
  institutionId      String?
  institutionName    String?
  transactionsCursor String? // Plaid transactions/sync cursor
  accounts           Account[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Account {
  id               String        @id @default(cuid())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  plaidItem        PlaidItem     @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  plaidItemId      String
  plaidAccountId   String        @unique
  name             String
  officialName     String?
  mask             String? // last 4
  type             String? // depository, investment, etc.
  subtype          String?
  institutionName  String?
  currentBalance   Float?
  availableBalance Float?
  isoCurrencyCode  String?
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Transaction {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId          String
  plaidTransactionId String   @unique
  date               DateTime
  // Plaid convention: positive = money out of the account, negative = money in.
  amount             Float
  name               String
  merchantName       String?
  category           String?
  pending            Boolean  @default(false)
  isTransfer         Boolean  @default(false) // Plaid-category transfer hint (any transfer)
  isoCurrencyCode    String?
  createdAt          DateTime @default(now())

  // Input-payment addendum (spec §3.5)
  isSelfTransfer Boolean   @default(false) // confirmed +/- pair between user's own accounts
  incomeTag      IncomeTag @default(UNTAGGED)
  // Reconciliation: 1:1 link to a merged ManualPayment (back-side of the relation).
  reconciledManualPayment ManualPayment? @relation("Reconciliation")

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// Rules engine (spec §2.4) & Alerts (spec §2.5)
// ---------------------------------------------------------------------------

enum RuleType {
  TAX_SET_ASIDE // percent of NIL income
  MONTHLY_SAVINGS // dollars/month target
  SPENDING_THRESHOLD // dollars/month ceiling
}

enum RuleUnit {
  PERCENT
  DOLLARS
}

model Rule {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        RuleType
  value       Float
  unit        RuleUnit
  explanation String // one-line plain-English "why"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, type])
}

enum AlertType {
  SPENDING
  TAX_REMINDER
  LARGE_DEPOSIT
  TAG_INCOME
}

model Alert {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        AlertType
  title       String
  body        String
  dedupeKey   String // stable key so the same alert isn't created twice
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Goals — "Next Season" life-after-sport planning (the differentiator)
// ---------------------------------------------------------------------------

enum GoalCategory {
  HOME
  BUSINESS
  EDUCATION
  FAMILY
  INDEPENDENCE
  REAL_ESTATE
  OTHER
}

model Goal {
  id                  String       @id @default(cuid())
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  title               String
  category            GoalCategory
  targetAmount        Float
  targetDate          DateTime
  monthlyContribution Float        @default(0)
  // DEPRECATED by the input-payment addendum: progress is now SUM(GoalAllocation.amount),
  // computed on read. Existing values are backfilled into a MANUAL_ADHOC allocation.
  currentSaved        Float        @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  allocations GoalAllocation[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Input Payment & Reconciliation addendum (playbook-input-payment-spec.md §3)
// Money amounts use Float to match the existing Transaction.amount (so the
// reconciliation match math compares like-for-like); values are rounded to cents.
// All totals (reserve target/marked, goal progress) are computed on read from
// these source records — never stored as running totals (spec non-negotiable).
// ---------------------------------------------------------------------------

enum ManualPaymentKind {
  NIL_DEAL
  OTHER_INCOME
}

enum PaymentMethod {
  CASH
  APP // Venmo / Cash App / etc.
  COLLECTIVE
  CHECK
}

enum ManualPaymentStatus {
  ACTIVE
  MERGED
  KEPT_SEPARATE
}

enum GoalAllocationSource {
  MANUAL_PAYMENT
  MANUAL_ADHOC
}

enum IncomeTag {
  UNTAGGED
  NIL_INCOME
  NOT_INCOME
}

model ManualPayment {
  id                String              @id @default(cuid())
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  amount            Float
  kind              ManualPaymentKind
  method            PaymentMethod
  payer             String?
  occurredOn        DateTime
  taxSetAsideAmount Float // snapshot of amount * set-aside rate, captured at log time
  status            ManualPaymentStatus @default(ACTIVE)

  // Reconciliation: when merged, links to the matched bank Transaction (1:1).
  reconciledTransaction   Transaction? @relation("Reconciliation", fields: [reconciledTransactionId], references: [id])
  reconciledTransactionId String?      @unique

  allocations GoalAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model GoalAllocation {
  id         String               @id @default(cuid())
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  goal       Goal                 @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalId     String
  amount     Float
  sourceType GoalAllocationSource

  // When sourced from a manual payment, deleting that payment cascades the allocation.
  sourceManualPayment   ManualPayment? @relation(fields: [sourceManualPaymentId], references: [id], onDelete: Cascade)
  sourceManualPaymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([goalId])
}

model ReserveMark {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  amount   Float
  markedAt DateTime @default(now())

  @@index([userId])
}

// Quarterly estimated-tax due dates (spec §8, decision §2.10): seeded data, not
// hardcoded. statutoryDate is the nominal date; the weekend/holiday →
// next-business-day adjustment is applied on read (lib/taxDates.ts, piece 6).
// NOTE: review/extend these annually.
model QuarterlyTaxDate {
  id            String   @id @default(cuid())
  taxYear       Int // tax year the estimated payment applies to
  quarter       Int // 1..4
  statutoryDate DateTime
  createdAt     DateTime @default(now())

  @@unique([taxYear, quarter])
}
