# ---------------------------------------------------------------------------
# Playbook environment variables. Copy this file to `.env` and fill in values.
# Never commit your real .env (it's gitignored).
# ---------------------------------------------------------------------------

# Postgres connection string. Use a free Neon (neon.tech) or Supabase project.
# Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/playbook?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/playbook?sslmode=require"

# Session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Encryption key for Plaid access tokens at rest (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Public base URL of the app (used for email verification links).
APP_URL="http://localhost:3000"

# Plaid (sandbox only for MVP). Get free sandbox keys at dashboard.plaid.com.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
